                    }
                ],
                "responses": {
                    "204": {
                        "description": "Succesfully added (no content)"
                    },
                    "304": {
                        "description": "Item template with name already exists"
                    },
                    "400": {
                        "description": "Invalid request body"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
